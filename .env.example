APP_NAME=HackForge
APP_VERSION=0.1.0
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production

# PostgreSQL connection string (local or production)
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hackforge
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

ALLOWED_ORIGINS=http://localhost:4174,http://localhost:5173
FRONTEND_URL=http://localhost:4174
# Cloudinary (required for form file-upload questions)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
